# ═══════════════════════════════════════════════════════════════
# Siyadah Orchestrator — copy to .env and fill in real values
# ═══════════════════════════════════════════════════════════════

# --- Activepieces ---
AP_BASE_URL=https://your-activepieces-host.example.com
AP_EMAIL=your-sign-in-email@example.com
AP_PASSWORD=your-activepieces-password
AP_PROJECT_ID=your-default-project-id

AP_MCP_SERVER_URL=https://your-activepieces-host.example.com/api/v1/projects/YOUR_PROJECT_ID/mcp-server/http
AP_MCP_TOKEN=your-mcp-bearer-token
# Optional Railway alias (read if AP_MCP_TOKEN is empty):
AP_TOKEN=

# --- Piece connections (Activepieces externalId) ---
GMAIL_CONNECTION_ID=
SHEETS_CONNECTION_ID=

# --- Postgres / Redis (Railway private or public proxy URLs) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# --- Orchestrator ---
ORCHESTRATOR_API_KEY=generate-a-strong-secret
ORCHESTRATOR_URL=https://your-orchestrator-host.example.com
# CSV of origins allowed to call /v2/* with credentials. If unset the
# orchestrator falls back to https://app.siyadah.ai (never "*" — browsers
# would echo any origin and defeat allow_credentials).
ORCHESTRATOR_ALLOWED_ORIGINS=https://app.siyadah.ai,https://staging.siyadah.ai

# --- Wave-1 multi-tenancy enforcement ---
# false  → dry-run: require_tenant logs violations to tenant_audit_log
#                   but requests pass through. Use while BFF rolls out
#                   X-Siyadah-Tenant header injection.
# true   → enforce: violations return 401/403.
# Flip to true only after 24h of zero violations in tenant_audit_log.
REQUIRE_TENANT_ENFORCE=false

# --- Postgres TLS (F3 remediation) ---
# Set PG_CA_BUNDLE to the path of Railway's CA bundle to enable
# verified TLS with hostname check. If you must keep the legacy
# CERT_NONE behaviour during the rollout window, set
# SIYADAH_SKIP_PG_SSL=1 — the process will emit a loud warning every
# start until this is unset. One of the two MUST be set, otherwise
# the orchestrator refuses to start.
PG_CA_BUNDLE=/etc/ssl/certs/railway-ca.pem
# SIYADAH_SKIP_PG_SSL=1

# --- Phase 3 observability (optional) ---
# LOG_LEVEL controls structlog verbosity. DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
# Leave SENTRY_DSN blank to disable error reporting. When set, all
# /v2/* errors are shipped to Sentry with tenant_id / request_id
# tags. PII scrubbing is on by default.
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# --- External APIs ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
FIRECRAWL_API_KEY=fc-xxxxx

# --- Activepieces server only (not used by this repo's Python code) ---
# AP_API_KEY=platform-key-if-you-use-admin-api
# AP_ENCRYPTION_KEY=...
# AP_JWT_SECRET=...
