{
  "actions": {
    "create_new_gdrive_file": {
      "description": "Create a new text file in your Google Drive from text",
      "displayName": "Create new file",
      "dropdown_fields": [
        "parentFolder"
      ],
      "dynamic_fields": [],
      "property_types": {
        "fileName": "SHORT_TEXT",
        "fileType": "STATIC_DROPDOWN",
        "include_team_drives": "CHECKBOX",
        "parentFolder": "DROPDOWN",
        "text": "LONG_TEXT"
      },
      "props": {
        "fileName": {
          "description": "The name of the new text file",
          "displayName": "File name",
          "required": true,
          "type": "SHORT_TEXT"
        },
        "fileType": {
          "defaultValue": "plain/text",
          "description": "Select file type",
          "displayName": "Content type",
          "options": {
            "options": [
              {
                "label": "Text",
                "value": "plain/text"
              },
              {
                "label": "CSV",
                "value": "text/csv"
              },
              {
                "label": "XML",
                "value": "text/xml"
              }
            ]
          },
          "required": true,
          "type": "STATIC_DROPDOWN"
        },
        "include_team_drives": {
          "defaultValue": false,
          "description": "Determines if folders from Team Drives should be included in the results.",
          "displayName": "Include Team Drives",
          "required": false,
          "type": "CHECKBOX"
        },
        "parentFolder": {
          "auth": [
            {
              "authUrl": "https://accounts.google.com/o/oauth2/auth",
              "description": "",
              "displayName": "Connection",
              "required": true,
              "scope": [
                "https://www.googleapis.com/auth/drive"
              ],
              "tokenUrl": "https://oauth2.googleapis.com/token",
              "type": "OAUTH2"
            },
            {
              "description": "Authenticate via service account from https://console.cloud.google.com/ > IAM & Admin > Service Accounts > Create Service Account > Keys > Add key.  <br> <br> You can optionally use domain-wide delegation (https://support.google.com/a/answer/162106?hl=en#zippy=%2Cset-up-domain-wide-delegation-for-a-client) to access files without adding the service account to each one. <br> <br> **Note:** Without a user email, the service account only has access to files/folders you explicitly share with it.",
              "displayName": "Service Account (Advanced)",
              "props": {
                "serviceAccount": {
                  "displayName": "Service Account JSON Key",
                  "required": true,
                  "type": "LONG_TEXT"
                },
                "userEmail": {
                  "description": "Email address of the user to impersonate for domain-wide delegation.",
                  "displayName": "User Email",
                  "required": false,
                  "type": "SHORT_TEXT"
                }
              },
              "required": true,
              "type": "CUSTOM_AUTH"
            }
          ],
          "description": "The Drive folder to target. Leave empty to use the root of My Drive. Type in the box to search your Drive by folder name. If the folder still isn't listed, switch this field to 'Dynamic value' (the toggle next to the field) and paste the folder ID — you can copy it from the folder's URL in Drive, after /folders/ (e.g. https://drive.google.com/drive/folders/<FOLDER_ID>).",
          "displayName": "Parent Folder",
          "refreshOnSearch": true,
          "refreshers": [
            "include_team_drives"
          ],
          "required": false,
          "type": "DROPDOWN"
        },
        "text": {
          "description": "The text content to add to file",
          "displayName": "Text",
          "required": true,
          "type": "LONG_TEXT"
        }
      },
      "required_fields": [
        "fileName",
        "fileType",
        "text"
      ]
    },
