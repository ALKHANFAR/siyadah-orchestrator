    "create_draft_reply": {
      "description": "Creates a draft reply to an existing email.",
      "displayName": "Create Draft Reply",
      "dropdown_fields": [
        "message_id"
      ],
      "dynamic_fields": [],
      "property_types": {
        "attachment": "FILE",
        "attachment_name": "SHORT_TEXT",
        "body": "LONG_TEXT",
        "body_type": "STATIC_DROPDOWN",
        "include_original_message": "CHECKBOX",
        "message_id": "DROPDOWN",
        "reply_type": "STATIC_DROPDOWN",
        "sender_name": "SHORT_TEXT"
      },
      "props": {
        "attachment": {
          "description": "Optional file to attach to your draft reply",
          "displayName": "Attachment",
          "required": false,
          "type": "FILE"
        },
        "attachment_name": {
          "description": "Custom name for the attachment",
          "displayName": "Attachment Name",
          "required": false,
          "type": "SHORT_TEXT"
        },
        "body": {
          "description": "Your draft reply message content",
          "displayName": "Draft Reply Body",
          "required": false,
          "type": "LONG_TEXT"
        },
        "body_type": {
          "defaultValue": "plain_text",
          "displayName": "Body Type",
          "options": {
            "disabled": false,
            "options": [
              {
                "label": "Plain text",
                "value": "plain_text"
              },
              {
                "label": "HTML",
                "value": "html"
              }
            ]
          },
          "required": true,
          "type": "STATIC_DROPDOWN"
        },
        "include_original_message": {
          "defaultValue": true,
          "description": "Include the original message content in the draft reply",
          "displayName": "Include Original Message",
          "required": true,
          "type": "CHECKBOX"
        },
        "message_id": {
          "auth": [
            {
              "authUrl": "https://accounts.google.com/o/oauth2/auth",
              "description": "",
              "displayName": "Connection",
              "required": true,
              "scope": [
                "https://www.googleapis.com/auth/gmail.send",
                "https://www.googleapis.com/auth/gmail.readonly",
                "https://www.googleapis.com/auth/gmail.compose",
                "email"
              ],
              "tokenUrl": "https://oauth2.googleapis.com/token",
              "type": "OAUTH2"
            },
            {
              "description": "Authenticate via service account from https://console.cloud.google.com/ > IAM & Admin > Service Accounts > Create Service Account > Keys > Add key.  <br> <br> You can optionally use domain-wide delegation (https://support.google.com/a/answer/162106?hl=en#zippy=%2Cset-up-domain-wide-delegation-for-a-client) to access Gmail without adding the service account to each mailbox. <br> <br> **Note:** A user email with domain-wide delegation is required for Gmail service account access.",
              "displayName": "Service Account (Advanced)",
              "props": {
                "serviceAccount": {
                  "displayName": "Service Account JSON Key",
                  "required": true,
                  "type": "LONG_TEXT"
                },
                "userEmail": {
                  "description": "Email address of the user to impersonate. Required for Gmail service account access via domain-wide delegation.",
                  "displayName": "User Email",
                  "required": true,
                  "type": "SHORT_TEXT"
                }
              },
              "required": true,
              "type": "CUSTOM_AUTH"
            }
          ],
          "description": "Select a message from the list or enter a message ID manually.",
          "displayName": "Message",
          "refreshers": [],
          "required": true,
          "type": "DROPDOWN"
        },
        "reply_type": {
          "defaultValue": "reply",
          "description": "Choose whether to reply to sender only or to all recipients",
          "displayName": "Reply Type",
          "options": {
            "disabled": false,
            "options": [
              {
                "label": "Reply (to sender only)",
                "value": "reply"
              },
              {
                "label": "Reply All (to all recipients)",
                "value": "reply_all"
              }
