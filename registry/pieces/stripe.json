    "create_payment_intent": {
      "description": "Creates a new payment intent to start a payment flow.",
      "displayName": "Create Payment (Payment Intent)",
      "dropdown_fields": [
        "customer"
      ],
      "dynamic_fields": [],
      "property_types": {
        "amount": "NUMBER",
